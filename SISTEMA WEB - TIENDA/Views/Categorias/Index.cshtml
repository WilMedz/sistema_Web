@model IEnumerable<SISTEMA_WEB___TIENDA.Models.Categoria>
@{
    ViewData["Title"] = "Categorías"; Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .page-header {
        background: linear-gradient(135deg, #4a1020, #6b1a2a);
        border-radius: 14px;
        padding: 22px 28px;
        color: white;
        margin-bottom: 24px;
    }

        .page-header h4 {
            font-family: 'Playfair Display', serif;
            font-size: 1.4rem;
            margin: 0;
        }

    .tabla-admin th {
        background: #4a1020;
        color: white;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.8px;
    }

    .tabla-admin td {
        font-size: 0.875rem;
        vertical-align: middle;
    }

    .tabla-admin tbody tr:hover {
        background: #fdf8f8;
    }

    .btn-accion {
        padding: 5px 12px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        border: none;
        cursor: pointer;
        transition: opacity 0.2s;
    }

        .btn-accion:hover {
            opacity: 0.82;
        }
</style>

<div class="page-header d-flex align-items-center justify-content-between flex-wrap gap-3">
    <div>
        <p class="mb-1" style="font-size:0.7rem;letter-spacing:2px;color:rgba(255,255,255,0.55);text-transform:uppercase;"><i class="bi bi-collection me-1"></i>Config</p>
        <h4>Categorías</h4>
    </div>
    <div style="display:flex;gap:8px;">
        <a asp-action="Create" class="btn btn-sm fw-bold px-3" style="background:#c9a84c;color:#4a1020;border-radius:8px;"><i class="bi bi-plus-lg me-1"></i>Nueva</a>
        <a asp-controller="Login" asp-action="Admin" class="btn btn-sm" style="background:rgba(255,255,255,0.15);color:white;border-radius:8px;"><i class="bi bi-arrow-left me-1"></i>Dashboard</a>
    </div>
</div>

@if (TempData["OK"] != null)
{
    <div class="alert alert-success alert-dismissible fade show small py-2 mb-3">
        <i class="bi bi-check-circle me-1"></i>@TempData["OK"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm rounded-3 overflow-hidden">
    <div class="table-responsive">
        <table class="table tabla-admin align-middle mb-0">
            <thead><tr><th class="ps-3">ID</th><th>Nombre Categoría</th><th class="text-center pe-3">Acciones</th></tr></thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td class="ps-3 text-muted font-monospace" style="font-size:0.8rem;">@c.CategoriaId</td>
                        <td class="fw-semibold">@c.NombreCategoria</td>
                        <td class="text-center pe-3">
                            <div class="d-flex justify-content-center gap-1">
                                <a asp-action="Edit" asp-route-id="@c.CategoriaId" class="btn-accion text-white" style="background:#c9a84c;"><i class="bi bi-pencil"></i></a>
                                <form asp-action="Delete" asp-route-id="@c.CategoriaId" method="post" onsubmit="return confirm('¿Eliminar @c.NombreCategoria?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-accion text-white" style="background:#6b1a2a;"><i class="bi bi-trash3"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>