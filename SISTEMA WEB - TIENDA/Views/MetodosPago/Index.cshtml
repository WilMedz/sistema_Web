@model IEnumerable<SISTEMA_WEB___TIENDA.Models.MetodoPago>
@{
    ViewData["Title"] = "Métodos de Pago";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .page-header {
        background: linear-gradient(135deg, #4a1020 0%, #6b1a2a 60%, #8c2438 100%);
        border-radius: 14px;
        padding: 22px 28px;
        color: white;
        margin-bottom: 24px;
        position: relative;
        overflow: hidden;
    }

        .page-header h4 {
            font-family: 'Playfair Display', serif;
            font-size: 1.4rem;
            margin: 0;
        }

    .tabla-admin th {
        background: #4a1020;
        color: white;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.8px;
    }

    .tabla-admin td {
        font-size: 0.875rem;
        vertical-align: middle;
    }

    .btn-accion {
        padding: 5px 12px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        transition: opacity 0.2s;
    }

        .btn-accion:hover {
            opacity: 0.82;
        }
</style>

<div class="page-header d-flex align-items-center justify-content-between flex-wrap gap-3">
    <div style="position:relative;z-index:1;">
        <p class="mb-1" style="font-size:0.7rem;letter-spacing:2px;color:rgba(255,255,255,0.55);text-transform:uppercase;">
            <i class="bi bi-credit-card me-1"></i>Configuración
        </p>
        <h4>Métodos de Pago</h4>
    </div>
    <div style="position:relative;z-index:1;display:flex;gap:8px;">
        <a asp-action="Create" class="btn btn-sm fw-bold px-3" style="background:#c9a84c;color:#4a1020;border-radius:8px;">
            <i class="bi bi-plus-lg me-1"></i>Nuevo Método
        </a>
        <a asp-controller="Login" asp-action="Admin" class="btn btn-sm" style="background:rgba(255,255,255,0.15);color:white;border-radius:8px;">
            <i class="bi bi-arrow-left me-1"></i>Dashboard
        </a>
    </div>
</div>

@if (TempData["OK"] != null)
{
    <div class="alert alert-success alert-dismissible fade show small py-2 mb-3">
        <i class="bi bi-check-circle me-1"></i>@TempData["OK"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm rounded-3 overflow-hidden">
    <div class="table-responsive">
        <table class="table tabla-admin align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-3">ID</th>
                    <th>Método de Pago</th>
                    <th class="text-center">Instrucciones / Enlace</th>
                    <th class="text-center pe-3">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model)
                {
                    <tr>
                        <td class="ps-3 font-monospace" style="color:#888;font-size:0.8rem;">@m.MetodoPagoId</td>
                        <td class="fw-semibold">@m.DescripcionPago</td>
                        <td class="text-center">
                            @if (m.DescripcionPago.ToLower().Contains("yape") || m.DescripcionPago.ToLower().Contains("plin"))
                            {
                                <a href="https://wa.me/519XXXXXXXX?text=Hola%20quiero%20pagar%20por%20Yape%20mi%20pedido" target="_blank" class="badge bg-success text-white text-decoration-none p-2">
                                    <i class="bi bi-whatsapp me-1"></i>Pagar por WhatsApp
                                </a>
                            }
                            else if (m.DescripcionPago.ToLower().Contains("tarjeta"))
                            {
                                <button class="badge bg-primary border-0 text-white p-2" onclick="alert('Simulación de pago con tarjeta exitosa.')">
                                    <i class="bi bi-credit-card-2-front me-1"></i>Simular Pago
                                </button>
                            }
                            else if (m.DescripcionPago.ToLower().Contains("efectivo"))
                            {
                                <span class="badge bg-secondary text-white p-2">
                                    <i class="bi bi-cash-coin me-1"></i>Pagar en tienda
                                </span>
                            }
                            else
                            {
                                <span class="text-muted small">Sin instrucciones</span>
                            }
                        </td>
                        <td class="text-center pe-3">
                            <div class="d-flex justify-content-center gap-1">
                                <a asp-action="Edit" asp-route-id="@m.MetodoPagoId" class="btn-accion text-white" style="background:#c9a84c;">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@m.MetodoPagoId" method="post" onsubmit="return confirm('¿Eliminar el método @m.DescripcionPago?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-accion text-white" style="background:#6b1a2a;">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>