@model SISTEMA_WEB___TIENDA.Models.MetodoPago
@{
    ViewData["Title"] = "Nuevo Método de Pago";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .form-header {
        background: linear-gradient(135deg, #4a1020, #6b1a2a);
        border-radius: 14px;
        padding: 22px 28px;
        color: white;
        margin-bottom: 24px;
    }

        .form-header h4 {
            font-family: 'Playfair Display', serif;
            font-size: 1.4rem;
            margin: 0;
        }

    .form-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(107,26,42,0.07);
        padding: 28px;
    }

    .field-label {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #888;
        margin-bottom: 6px;
        display: block;
    }

    .field-input {
        width: 100%;
        border: none;
        border-bottom: 1.5px solid #ddd;
        padding: 9px 0;
        font-size: 0.9rem;
        font-family: 'Inter', sans-serif;
        background: transparent;
        outline: none;
        transition: border-color 0.2s;
    }

        .field-input:focus {
            border-bottom-color: #6b1a2a;
        }

    .btn-guardar {
        background: #6b1a2a;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 11px 28px;
        font-size: 0.82rem;
        font-weight: 600;
        text-transform: uppercase;
        font-family: 'Inter', sans-serif;
        cursor: pointer;
    }

    .btn-cancelar {
        background: transparent;
        color: #888;
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 11px 20px;
        font-size: 0.82rem;
        text-decoration: none;
    }

        .btn-cancelar:hover {
            border-color: #6b1a2a;
            color: #6b1a2a;
        }
</style>

<div class="form-header">
    <p class="mb-1" style="font-size:0.7rem;color:rgba(255,255,255,0.55);text-transform:uppercase;letter-spacing:2px;">
        <i class="bi bi-credit-card-fill me-1"></i>Métodos de Pago
    </p>
    <h4>Nuevo Método de Pago</h4>
</div>

<div class="form-card" style="max-width:500px;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="alert alert-danger small py-2 mb-3"></div>

        <label class="field-label">Descripción</label>
        <input asp-for="DescripcionPago" class="field-input" placeholder="Ej: Yape, Tarjeta, Efectivo..." />
        <span asp-validation-for="DescripcionPago" class="text-danger" style="font-size:0.72rem;"></span>

        <div class="d-flex gap-3 mt-4">
            <button type="submit" class="btn-guardar">
                <i class="bi bi-check-lg me-2"></i>GUARDAR
            </button>
            <a asp-action="Index" class="btn-cancelar">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}