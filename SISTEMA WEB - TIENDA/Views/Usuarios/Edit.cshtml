@model SISTEMA_WEB___TIENDA.Models.Clientes
@{
    ViewData["Title"] = "Editar Usuario";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .form-header {
        background: linear-gradient(135deg, #1a4a8a, #1c3d6b);
        border-radius: 14px;
        padding: 22px 28px;
        color: white;
        margin-bottom: 24px;
    }
        .form-header h4 { font-family: 'Playfair Display', serif; font-size: 1.4rem; margin: 0; }
    .form-card {
        background: white; border-radius: 12px;
        box-shadow: 0 2px 12px rgba(26,74,138,0.07); padding: 28px;
    }
    .field-label {
        font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: 1px; color: #888; margin-bottom: 6px; display: block;
    }
    .field-input {
        width: 100%; border: none; border-bottom: 1.5px solid #ddd;
        border-radius: 0; padding: 9px 0; font-size: 0.9rem;
        font-family: 'Inter', sans-serif; background: transparent;
        outline: none; transition: border-color 0.2s;
    }
        .field-input:focus { border-bottom-color: #1a4a8a; }
    .section-divider {
        font-size: 0.67rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: 2px; color: #aaa; margin: 24px 0 16px;
        border-bottom: 1px solid #f0f0f0; padding-bottom: 8px;
    }
    .btn-guardar {
        background: #1a4a8a; color: white; border: none; border-radius: 8px;
        padding: 11px 28px; font-size: 0.82rem; font-weight: 600;
        letter-spacing: 1px; text-transform: uppercase;
        font-family: 'Inter', sans-serif; cursor: pointer; transition: background 0.2s;
    }
        .btn-guardar:hover { background: #0f2d5c; }
    .btn-cancelar {
        background: transparent; color: #888; border: 1px solid #ddd;
        border-radius: 8px; padding: 11px 20px; font-size: 0.82rem;
        font-weight: 500; text-decoration: none; transition: all 0.2s;
    }
        .btn-cancelar:hover { border-color: #1a4a8a; color: #1a4a8a; }
    .hint { font-size: 0.72rem; color: #aaa; margin-top: 4px; }
</style>

<div class="form-header">
    <div>
        <p class="mb-1" style="font-size:0.7rem;letter-spacing:2px;color:rgba(255,255,255,0.55);text-transform:uppercase;">
            <i class="bi bi-pencil me-1"></i>Usuarios
        </p>
        <h4>Editar Usuario</h4>
    </div>
</div>

<div class="form-card">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ClienteId" />
        <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2 mb-3"></div>

        <div class="section-divider">Datos Personales</div>
        <div class="row g-4">
            <div class="col-md-6">
                <label class="field-label">Nombre Completo</label>
                <input asp-for="Nombres" class="field-input" />
                <span asp-validation-for="Nombres" class="text-danger" style="font-size:0.72rem;"></span>
            </div>
            <div class="col-md-6">
                <label class="field-label">Correo Electrónico</label>
                <input asp-for="CorreoElectronico" class="field-input" />
                <span asp-validation-for="CorreoElectronico" class="text-danger" style="font-size:0.72rem;"></span>
            </div>
            <div class="col-md-4">
                <label class="field-label">Fecha de Nacimiento</label>
                <input asp-for="FechaNacimiento" class="field-input" type="date" />
                <span asp-validation-for="FechaNacimiento" class="text-danger" style="font-size:0.72rem;"></span>
            </div>
            <div class="col-md-4">
                <label class="field-label">Ciudad</label>
                <select asp-for="CiudadId" class="field-input" asp-items="ViewBag.Ciudades">
                    <option value="">— Selecciona —</option>
                </select>
                <span asp-validation-for="CiudadId" class="text-danger" style="font-size:0.72rem;"></span>
            </div>
            <div class="col-md-4">
                <label class="field-label">Rol</label>
                <select asp-for="RolId" class="field-input" asp-items="ViewBag.Roles">
                    <option value="">— Selecciona —</option>
                </select>
                <span asp-validation-for="RolId" class="text-danger" style="font-size:0.72rem;"></span>
            </div>
        </div>

        <div class="section-divider">Cambiar Contraseña</div>
        <div class="row g-4">
            <div class="col-md-6">
                <label class="field-label">Nueva Contraseña</label>
                <input name="NuevaContrasena" type="password" class="field-input"
                       placeholder="Dejar vacío para no cambiar" />
                <p class="hint"><i class="bi bi-info-circle me-1"></i>Solo completa si deseas cambiar la contraseña.</p>
            </div>
        </div>

        <div class="d-flex gap-3 mt-4">
            <button type="submit" class="btn-guardar">
                <i class="bi bi-check-lg me-2"></i>GUARDAR CAMBIOS
            </button>
            <a asp-action="Index" class="btn-cancelar">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}