@model SISTEMA_WEB___TIENDA.ViewModels.RegistroVM
@{
    ViewData["Title"] = "Crear Cuenta";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registro — ALEANA STORE</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Inter', sans-serif; min-height: 100vh; background: #faf9f7; display: flex; }

        .registro-wrapper { display: flex; width: 100%; min-height: 100vh; }

        .registro-left {
            flex: 1;
            background: linear-gradient(135deg, #4a1020 0%, #6b1a2a 50%, #c9a84c 100%);
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            position: relative; overflow: hidden;
        }
        .registro-left::before {
            content: '';
            position: absolute;
            width: 400px; height: 400px;
            background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%);
            top: -80px; left: -80px; border-radius: 50%;
        }
        .registro-left .tagline {
            font-family: 'Playfair Display', serif;
            font-size: 2.8rem;
            font-weight: 700;
            color: white;
            z-index: 1;
            text-align: center;
            line-height: 1.2;
            padding: 0 40px;
        }
        .registro-left .tagline-sub {
            color: rgba(255,255,255,0.6);
            font-size: 0.85rem;
            margin-top: 12px;
            z-index: 1;
            text-align: center;
            max-width: 280px;
        }

        .registro-right {
            width: 480px;
            min-width: 380px;
            background: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 48px 44px;
            box-shadow: -4px 0 24px rgba(0,0,0,0.06);
            overflow-y: auto;
        }

        .brand {
            font-family: 'Playfair Display', serif;
            font-size: 1.4rem;
            font-weight: 700;
            color: #6b1a2a;
            letter-spacing: 3px;
            margin-bottom: 4px;
        }
        .subtitle { font-size: 0.78rem; color: #aaa; margin-bottom: 32px; }

        .form-label-custom {
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #888;
            margin-bottom: 5px;
            display: block;
        }
        .form-control-custom, .form-select-custom {
            width: 100%;
            border: none;
            border-bottom: 1.5px solid #ddd;
            border-radius: 0;
            padding: 9px 0;
            font-size: 0.88rem;
            font-family: 'Inter', sans-serif;
            background: transparent;
            outline: none;
            transition: border-color 0.2s;
        }
        .form-control-custom:focus, .form-select-custom:focus { border-bottom-color: #6b1a2a; }

        .btn-registro {
            width: 100%;
            background: #6b1a2a;
            color: white;
            border: none;
            border-radius: 8px;
            padding: 13px;
            font-size: 0.85rem;
            font-weight: 600;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            font-family: 'Inter', sans-serif;
            cursor: pointer;
            transition: background 0.2s;
            margin-top: 8px;
        }
        .btn-registro:hover { background: #4a1020; }

        .link-login {
            font-size: 0.8rem;
            color: #999;
            text-align: center;
            margin-top: 18px;
        }
        .link-login a { color: #6b1a2a; font-weight: 600; text-decoration: none; }

        @@media (max-width: 768px) {
            .registro-left { display: none; }
            .registro-right { width: 100%; min-width: unset; }
        }
    </style>
</head>
<body>
<div class="registro-wrapper">

    <!-- PANEL IZQUIERDO -->
    <div class="registro-left">
        <div class="tagline">Únete a<br>Aleana Store.</div>
        <div class="tagline-sub">Las mejores prendas de temporada en Cajamarca.</div>
    </div>

    <!-- FORMULARIO -->
    <div class="registro-right">
        <div class="brand">ALEANA</div>
        <div class="subtitle">Crea tu cuenta de cliente</div>

        <form asp-action="Registro" asp-controller="Login" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label-custom">Nombres Completos</label>
                <input asp-for="Nombres" class="form-control-custom" placeholder="Ej: María Pérez Torres" />
                <span asp-validation-for="Nombres" class="text-danger" style="font-size:0.72rem;"></span>
            </div>

            <div class="mb-3">
                <label class="form-label-custom">Correo Electrónico</label>
                <input asp-for="CorreoElectronico" class="form-control-custom" placeholder="correo@ejemplo.com" />
                <span asp-validation-for="CorreoElectronico" class="text-danger" style="font-size:0.72rem;"></span>
            </div>

            <div class="mb-3">
                <label class="form-label-custom">Ciudad</label>
                <select asp-for="CiudadId" class="form-select-custom" asp-items="ViewBag.Ciudades">
                    <option value="">— Selecciona —</option>
                </select>
                <span asp-validation-for="CiudadId" class="text-danger" style="font-size:0.72rem;"></span>
            </div>

            <div class="mb-3">
                <label class="form-label-custom">Fecha de Nacimiento</label>
                <input asp-for="FechaNacimiento" type="date" class="form-control-custom" />
                <span asp-validation-for="FechaNacimiento" class="text-danger" style="font-size:0.72rem;"></span>
            </div>

            <div class="mb-3">
                <label class="form-label-custom">Contraseña</label>
                <input asp-for="Contrasena" type="password" class="form-control-custom" placeholder="Mínimo 6 caracteres" />
                <span asp-validation-for="Contrasena" class="text-danger" style="font-size:0.72rem;"></span>
            </div>

            <div class="mb-4">
                <label class="form-label-custom">Confirmar Contraseña</label>
                <input asp-for="ConfirmarContrasena" type="password" class="form-control-custom" placeholder="Repite tu contraseña" />
                <span asp-validation-for="ConfirmarContrasena" class="text-danger" style="font-size:0.72rem;"></span>
            </div>

            <button type="submit" class="btn-registro">
                <i class="bi bi-person-check me-2"></i>CREAR MI CUENTA
            </button>
        </form>

        <div class="link-login">
            ¿Ya tienes cuenta? <a asp-action="Login" asp-controller="Login">Inicia sesión</a>
        </div>
    </div>

</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
</body>
</html>