@using Microsoft.AspNetCore.Http
@using SISTEMA_WEB___TIENDA.Extensions
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ALEANA STORE</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
            :root {
                --granate: #6b1a2a;
                --granate-dark: #4a1020;
                --granate-soft: #8c2438;
                --gold: #c9a84c;
                --light: #faf9f7;
                --text: #1c1c1c;
            }

            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: 'Inter', sans-serif;
                background: var(--light);
                color: var(--text);
                display: flex;
                flex-direction: column;
                min-height: 100vh;
            }

            h1, h2, h3, h4, h5 {
                font-family: 'Playfair Display', serif;
            }

            .topbar {
                background: var(--granate-dark);
                color: rgba(255,255,255,0.75);
                font-size: 0.72rem;
                text-align: center;
                padding: 6px 0;
                letter-spacing: 0.5px;
            }

            .navbar-aleana {
                background: white;
                border-bottom: 2px solid var(--granate);
                padding: 14px 0;
                position: sticky;
                top: 0;
                z-index: 1000;
                box-shadow: 0 2px 12px rgba(107,26,42,0.08);
            }

                .navbar-aleana .brand {
                    font-family: 'Playfair Display', serif;
                    font-size: 1.5rem;
                    font-weight: 700;
                    color: var(--granate);
                    text-decoration: none;
                    letter-spacing: 3px;
                }

                .navbar-aleana .nav-link-item {
                    color: #555;
                    text-decoration: none;
                    font-size: 0.82rem;
                    font-weight: 500;
                    padding: 6px 12px;
                    border-radius: 6px;
                    transition: all 0.2s;
                    letter-spacing: 0.3px;
                }

                    .navbar-aleana .nav-link-item:hover {
                        color: var(--granate);
                        background: rgba(107,26,42,0.06);
                    }

                .navbar-aleana .search-box {
                    border: 1px solid #ddd;
                    border-radius: 20px;
                    padding: 7px 16px;
                    font-size: 0.82rem;
                    width: 260px;
                    font-family: 'Inter', sans-serif;
                    transition: all 0.2s;
                    background: #faf9f7;
                }

                    .navbar-aleana .search-box:focus {
                        outline: none;
                        border-color: var(--granate);
                        box-shadow: 0 0 0 3px rgba(107,26,42,0.08);
                    }

            /* DISEÑO DE LA LISTA DESPLEGABLE PREDICTIVA */
            .search-wrapper {
                position: relative;
                width: 260px;
            }

            .search-dropdown {
                position: absolute;
                top: 100%;
                left: 0;
                width: 100%;
                background: white;
                border: 1px solid #e0e0e0;
                border-radius: 8px;
                box-shadow: 0 8px 24px rgba(0,0,0,0.12);
                max-height: 320px;
                overflow-y: auto;
                z-index: 1100;
                margin-top: 5px;
                display: none;
            }

            .search-item {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 10px 14px;
                text-decoration: none;
                color: var(--text);
                border-bottom: 1px solid #f5f5f5;
                transition: background 0.15s;
            }

                .search-item:last-child {
                    border-bottom: none;
                }

                .search-item:hover {
                    background: rgba(107,26,42,0.04);
                    color: var(--granate);
                }

                .search-item img {
                    width: 40px;
                    height: 40px;
                    object-fit: cover;
                    border-radius: 4px;
                    background: #f0f0f0;
                }

                .search-item .info {
                    display: flex;
                    flex-direction: column;
                    overflow: hidden;
                }

                .search-item .title {
                    font-size: 0.8rem;
                    font-weight: 500;
                    white-space: nowrap;
                    overflow: hidden;
                    text-overflow: ellipsis;
                }

                .search-item .price {
                    font-size: 0.75rem;
                    color: var(--granate-soft);
                    font-weight: 600;
                }

            .search-no-results {
                padding: 14px;
                text-align: center;
                font-size: 0.8rem;
                color: #888;
            }

            .btn-bolsa {
                background: var(--granate);
                color: white;
                font-weight: 600;
                font-size: 0.82rem;
                padding: 8px 18px;
                border-radius: 20px;
                text-decoration: none;
                transition: background 0.2s;
                white-space: nowrap;
            }

                .btn-bolsa:hover {
                    background: var(--granate-dark);
                    color: white;
                }

            .page-content {
                flex: 1;
                padding: 36px 0 56px;
            }

            footer {
                background: var(--granate-dark);
                color: rgba(255,255,255,0.55);
                font-size: 0.78rem;
                padding: 18px 0;
                text-align: center;
                font-family: 'Inter', sans-serif;
            }

                footer strong {
                    color: var(--gold);
                }

                footer a {
                    color: var(--gold);
                    text-decoration: none;
                }

                    footer a:hover {
                        text-decoration: underline;
                    }
    </style>
</head>
<body>

    <div class="topbar">
        Envíos a Cajamarca y toda la región &nbsp;·&nbsp; Lunes a Sábado 9am – 7pm
    </div>

    <nav class="navbar-aleana">
        <div class="container d-flex align-items-center gap-3">

            <a href="/" class="brand">ALEANA</a>

            <div class="flex-grow-1 d-none d-lg-flex justify-content-center">
                <div class="search-wrapper">
                    <form asp-controller="Home" asp-action="Index" method="get" class="m-0" id="form-busqueda">
                        <input type="text" id="input-buscar" name="buscar" class="search-box" autocomplete="off" placeholder="🔍  Buscar prendas..." value="@Context.Request.Query["buscar"]">
                    </form>
                    <div id="resultados-busqueda" class="search-dropdown"></div>
                </div>
            </div>

            <div class="d-flex align-items-center gap-1 ms-auto">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    var rol = HttpContextAccessor.HttpContext?.Session.GetString("UsuarioRol") ?? "";
                    var nombre = HttpContextAccessor.HttpContext?.Session.GetString("UsuarioNombre") ?? "";
                    var carrito = HttpContextAccessor.HttpContext?.Session
                                        .GetObject<List<SISTEMA_WEB___TIENDA.Models.CarritoItem>>("CarritoAleana")
                                     ?? new List<SISTEMA_WEB___TIENDA.Models.CarritoItem>();
                    var totalItems = carrito.Sum(i => i.Cantidad);

                    if (rol == "Administrador")
                    {
                        <a asp-controller="Login" asp-action="Admin" class="nav-link-item">
                            <i class="bi bi-speedometer2"></i>
                            <span class="d-none d-md-inline ms-1">Dashboard</span>
                        </a>
                    }
                    else if (rol == "Cajero")
                    {
                        <a asp-controller="Caja" asp-action="Index" class="nav-link-item">
                            <i class="bi bi-receipt"></i>
                            <span class="d-none d-md-inline ms-1">Caja</span>
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Home" asp-action="Index" class="nav-link-item">
                            <i class="bi bi-grid"></i>
                            <span class="d-none d-md-inline ms-1">Catálogo</span>
                        </a>
                        
                        <a asp-controller="Home" asp-action="MisPedidos" class="nav-link-item">
                            <i class="bi bi-truck"></i>
                            <span class="d-none d-md-inline ms-1">Rastrear Pedido</span>
                        </a>
                    }

                    <a asp-controller="Account" asp-action="Index" class="nav-link-item">
                        <i class="bi bi-person-circle"></i>
                        <span class="d-none d-md-inline ms-1">@nombre.Split(' ').First()</span>
                    </a>

                    <form asp-controller="Login" asp-action="Logout" method="post" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="nav-link-item border-0 bg-transparent">
                            <i class="bi bi-box-arrow-right"></i>
                            <span class="d-none d-md-inline ms-1">Salir</span>
                        </button>
                    </form>

                    @if (rol == "Cliente" || rol == "")
                    {
                        <a asp-controller="Carrito" asp-action="Index" class="btn-bolsa position-relative ms-2">
                            <i class="bi bi-bag"></i>
                            <span class="ms-1">Bolsa</span>
                            @if (totalItems > 0)
                            {
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark"
                                      style="font-size:0.58rem; padding:3px 5px;">
                                    @totalItems
                                </span>
                            }
                        </a>
                    }
                }
                else
                {
                    <a asp-controller="Login" asp-action="Login" class="btn-bolsa">
                        <i class="bi bi-person me-1"></i>Iniciar Sesión
                    </a>
                }
            </div>

        </div>
    </nav>

    <div class="page-content">
        <div class="container">
            @RenderBody()
        </div>
    </div>

    <footer>
        <div class="container">
            &copy; 2026 &nbsp;<strong>ALEANA STORE</strong>&nbsp; — Cajamarca, Perú
            &nbsp;|&nbsp;
            <a asp-controller="Home" asp-action="Privacy">Privacidad</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
            document.addEventListener("DOMContentLoaded", function () {
                const inputBuscar = document.getElementById("input-buscar");
                const resultadosDiv = document.getElementById("resultados-busqueda");

                if (inputBuscar && resultadosDiv) {
                    inputBuscar.addEventListener("input", function () {
                        const query = inputBuscar.value.trim();

                        if (query.length < 2) {
                            resultadosDiv.innerHTML = "";
                            resultadosDiv.style.display = "none";
                            return;
                        }

                        // Petición AJAX en vivo al controlador
                        fetch(`/Home/BuscarSugerencias?term=${encodeURIComponent(query)}`)
                            .then(response => response.json())
                            .then(data => {
                                resultadosDiv.innerHTML = "";
                                if (data.length === 0) {
                                    resultadosDiv.innerHTML = '<div class="search-no-results">No se encontraron prendas</div>';
                                } else {
                                    data.forEach(item => {
                                        const a = document.createElement("a");
                                        a.href = `/Home/Index?buscar=${encodeURIComponent(item.nombre)}`;
                                        a.className = "search-item";
                                    
                                        // Validamos si tiene imagen, sino ponemos una por defecto
                                        const imgUrl = item.imagen ? item.imagen : '/images/no-image.png';
                                    
                                        a.innerHTML = `
                                            <img src="${imgUrl}" alt="${item.nombre}">
                                            <div class="info">
                                                <span class="title">${item.nombre}</span>
                                                <span class="price">S/ ${item.precio.toFixed(2)}</span>
                                            </div>
                                        `;
                                        resultadosDiv.appendChild(a);
                                    });
                                }
                                resultadosDiv.style.display = "block";
                            })
                            .catch(err => console.error("Error en autocompletado:", err));
                    });

                    // Cerrar la lista si se hace clic fuera del buscador
                    document.addEventListener("click", function (e) {
                        if (!inputBuscar.contains(e.target) && !resultadosDiv.contains(e.target)) {
                            resultadosDiv.style.display = "none";
                        }
                    });
                }
            });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>