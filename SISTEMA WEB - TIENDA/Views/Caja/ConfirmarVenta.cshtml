@{
    ViewData["Title"] = "Confirmar Venta";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var carrito = ViewBag.Carrito as List<SISTEMA_WEB___TIENDA.Models.CarritoItem>
                  ?? new List<SISTEMA_WEB___TIENDA.Models.CarritoItem>();
}

<style>
    .caja-header {
        background: linear-gradient(135deg, #198754, #146c43);
        color: white;
        border-radius: 12px;
        padding: 24px 28px;
        margin-bottom: 24px;
    }

    .form-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        padding: 28px;
    }

    .field-label {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #888;
        margin-bottom: 6px;
        display: block;
    }

    .field-input {
        width: 100%;
        border: none;
        border-bottom: 1.5px solid #ddd;
        padding: 9px 0;
        font-size: 0.9rem;
        background: transparent;
        outline: none;
        transition: border-color 0.2s;
        font-family: 'Inter', sans-serif;
    }

        .field-input:focus {
            border-bottom-color: #198754;
        }

    .section-divider {
        font-size: 0.67rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #aaa;
        margin: 20px 0 14px;
        border-bottom: 1px solid #f0f0f0;
        padding-bottom: 8px;
    }

    .btn-confirmar {
        background: #198754;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 12px 32px;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        cursor: pointer;
        transition: background 0.2s;
    }

        .btn-confirmar:hover {
            background: #146c43;
        }

    .btn-cancelar {
        background: transparent;
        color: #888;
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 12px 20px;
        font-size: 0.82rem;
        text-decoration: none;
    }

    .resumen-item {
        display: flex;
        justify-content: space-between;
        padding: 6px 0;
        border-bottom: 1px solid #f5f5f5;
        font-size: 0.85rem;
    }
</style>

<div class="caja-header d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div>
        <p class="mb-1 small" style="color:rgba(255,255,255,0.7);text-transform:uppercase;letter-spacing:1px;">
            <i class="bi bi-check2-circle me-1"></i>Módulo de Caja
        </p>
        <h4 class="fw-bold mb-0">Confirmar Venta</h4>
        <small style="color:rgba(255,255,255,0.6);">
            Paso 3 — Cliente: <strong>@ViewBag.ClienteNombre</strong>
        </small>
    </div>
    <a asp-action="SeleccionarProductos" class="btn btn-sm" style="background:rgba(255,255,255,0.15);color:white;border-radius:8px;">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

@if (TempData["ErrorVenta"] != null)
{
    <div class="alert alert-danger small py-2 mb-3">
        <i class="bi bi-exclamation-circle me-1"></i>@TempData["ErrorVenta"]
    </div>
}

<div class="row g-3">
    <div class="col-lg-7">
        <div class="form-card">
            <form asp-action="GenerarPedido" method="post">
                @Html.AntiForgeryToken()

                <div class="section-divider">Dirección de envío</div>
                <div class="row g-3">
                    <div class="col-12">
                        <label class="field-label">Calle / Avenida</label>
                        <input type="text" name="CalleAvenida" class="field-input" placeholder="Ej: Jr. Lima 123" required />
                    </div>
                    <div class="col-md-6">
                        <label class="field-label">Distrito</label>
                        <input type="text" name="Distrito" class="field-input" placeholder="Ej: Cajamarca" required />
                    </div>
                    <div class="col-md-6">
                        <label class="field-label">Referencia</label>
                        <input type="text" name="Referencia" class="field-input" placeholder="Ej: Frente al parque" required />
                    </div>
                </div>

                <div class="section-divider">Método de pago</div>
                <select name="MetodoPagoId" class="field-input" required>
                    <option value="">— Selecciona —</option>
                    @foreach (SelectListItem item in ViewBag.MetodosPago)
                    {
                        <option value="@item.Value">@item.Text</option>
                    }
                </select>

                <div class="d-flex gap-3 mt-4">
                    <button type="submit" class="btn-confirmar">
                        <i class="bi bi-check-lg me-2"></i>GENERAR PEDIDO
                    </button>
                    <a asp-action="SeleccionarProductos" class="btn-cancelar">Cancelar</a>
                </div>
            </form>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="form-card">
            <h6 style="font-family:'Playfair Display',serif;font-weight:600;margin-bottom:14px;">
                Resumen de la Venta
            </h6>
            @foreach (var item in carrito)
            {
                <div class="resumen-item">
                    <span>@item.NombrePrenda <small style="color:#aaa;">@item.Talla/@item.Color x@item.Cantidad</small></span>
                    <span class="fw-bold">S/ @item.Total.ToString("N2")</span>
                </div>
            }
            <div class="d-flex justify-content-between fw-bold mt-3 pt-2" style="border-top:2px solid #198754;font-size:1.05rem;">
                <span>Total a cobrar</span>
                <span style="color:#198754;">S/ @((ViewBag.GranTotal as decimal? ?? 0).ToString("N2"))</span>
            </div>
        </div>
    </div>
</div>