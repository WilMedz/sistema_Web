@model IEnumerable<SISTEMA_WEB___TIENDA.Models.VariantePrenda>
@{
    ViewData["Title"] = "Seleccionar Productos";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var carrito = ViewBag.Carrito as List<SISTEMA_WEB___TIENDA.Models.CarritoItem>
                  ?? new List<SISTEMA_WEB___TIENDA.Models.CarritoItem>();
}

<style>
    .caja-header {
        background: linear-gradient(135deg, #198754, #146c43);
        color: white;
        border-radius: 12px;
        padding: 24px 28px;
        margin-bottom: 24px;
    }

    .tabla-admin th {
        background: #146c43;
        color: white;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.8px;
    }

    .tabla-admin td {
        font-size: 0.875rem;
        vertical-align: middle;
    }

    .tabla-admin tbody tr:hover {
        background: #f0faf4;
    }

    .carrito-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        padding: 20px;
        position: sticky;
        top: 80px;
    }

    .btn-agregar {
        background: #198754;
        color: white;
        border: none;
        border-radius: 6px;
        padding: 5px 12px;
        font-size: 0.75rem;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.2s;
    }

        .btn-agregar:hover {
            opacity: 0.82;
        }

    .btn-quitar {
        background: #dc3545;
        color: white;
        border: none;
        border-radius: 6px;
        padding: 3px 8px;
        font-size: 0.72rem;
        cursor: pointer;
        transition: opacity 0.2s;
    }

        .btn-quitar:hover {
            opacity: 0.82;
        }

    .section-lbl {
        font-size: 0.67rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #aaa;
        margin-bottom: 12px;
    }

    .qty-input {
        width: 55px;
        border: 1px solid #ddd;
        border-radius: 6px;
        padding: 4px 6px;
        font-size: 0.82rem;
        text-align: center;
    }
</style>

<div class="caja-header d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div>
        <p class="mb-1 small" style="color:rgba(255,255,255,0.7);text-transform:uppercase;letter-spacing:1px;">
            <i class="bi bi-cart-plus me-1"></i>Módulo de Caja
        </p>
        <h4 class="fw-bold mb-0">Seleccionar Productos</h4>
        <small style="color:rgba(255,255,255,0.6);">
            Paso 2 — Cliente: <strong>@ViewBag.ClienteNombre</strong>
        </small>
    </div>
    <a asp-action="NuevaVenta" class="btn btn-sm" style="background:rgba(255,255,255,0.15);color:white;border-radius:8px;">
        <i class="bi bi-arrow-left me-1"></i>Cambiar Cliente
    </a>
</div>

@if (TempData["ErrorStock"] != null)
{
    <div class="alert alert-danger small py-2 mb-3">
        <i class="bi bi-exclamation-circle me-1"></i>@TempData["ErrorStock"]
    </div>
}

<div class="row g-3">
    <!-- PRODUCTOS -->
    <div class="col-lg-8">
        <div class="section-lbl">Productos disponibles (@Model.Count() variantes)</div>
        <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
            <div class="table-responsive">
                <table class="table tabla-admin align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-3">Prenda</th>
                            <th>Talla / Color</th>
                            <th class="text-center">Stock</th>
                            <th class="text-end">Precio</th>
                            <th class="text-center pe-3">Agregar</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in Model)
                        {
                            decimal precio = (v.Prenda.PrecioOferta.HasValue && v.Prenda.PrecioOferta > 0)
                                ? v.Prenda.PrecioOferta.Value : v.Prenda.PrecioLista;
                            <tr>
                                <td class="ps-3 fw-semibold">@v.Prenda.NombrePrenda</td>
                                <td style="color:#666;">@v.Talla / @v.Color</td>
                                <td class="text-center">
                                    <span style="background:#d1fae5;color:#065f46;border-radius:6px;padding:2px 8px;font-size:0.72rem;font-weight:700;">
                                        @v.Stock uds.
                                    </span>
                                </td>
                                <td class="text-end fw-bold" style="color:#198754;">S/ @precio.ToString("N2")</td>
                                <td class="text-center pe-3">
                                    <form asp-action="AgregarProducto" method="post" class="d-flex align-items-center justify-content-center gap-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="varianteId" value="@v.VarianteId" />
                                        <input type="number" name="cantidad" value="1" min="1" max="@v.Stock" class="qty-input" />
                                        <button type="submit" class="btn-agregar">
                                            <i class="bi bi-plus-lg"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- CARRITO -->
    <div class="col-lg-4">
        <div class="carrito-card">
            <h6 style="font-family:'Playfair Display',serif;font-weight:600;margin-bottom:16px;">
                <i class="bi bi-cart3 me-2" style="color:#198754;"></i>Venta Actual
            </h6>

            @if (!carrito.Any())
            {
                <div class="text-center py-3 text-muted" style="font-size:0.82rem;">
                    <i class="bi bi-cart-x" style="font-size:1.5rem;color:#ddd;display:block;margin-bottom:6px;"></i>
                    Sin productos agregados.
                </div>
            }
            else
            {
                @foreach (var item in carrito)
                {
                    <div class="d-flex align-items-center justify-content-between gap-2 mb-2 pb-2" style="border-bottom:1px solid #f0f0f0;">
                        <div style="flex:1;min-width:0;">
                            <div style="font-size:0.82rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                @item.NombrePrenda
                            </div>
                            <div style="font-size:0.72rem;color:#aaa;">
                                @item.Talla / @item.Color — x@item.Cantidad
                            </div>
                        </div>
                        <div style="font-size:0.85rem;font-weight:700;color:#198754;white-space:nowrap;">
                            S/ @item.Total.ToString("N2")
                        </div>
                        <form asp-action="QuitarProducto" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="varianteId" value="@item.VarianteId" />
                            <button type="submit" class="btn-quitar"><i class="bi bi-trash3"></i></button>
                        </form>
                    </div>
                }

                <div class="d-flex justify-content-between fw-bold mt-3 pt-2" style="border-top:2px solid #198754;">
                    <span>Total</span>
                    <span style="color:#198754;">S/ @((ViewBag.GranTotal as decimal? ?? 0).ToString("N2"))</span>
                </div>

                <a asp-action="ConfirmarVenta" class="d-block text-center text-white fw-bold mt-3 py-2 rounded-3"
                   style="background:#198754;text-decoration:none;font-size:0.82rem;">
                    <i class="bi bi-arrow-right-circle me-1"></i>CONFIRMAR VENTA
                </a>
            }
        </div>
    </div>
</div>