@model SISTEMA_WEB___TIENDA.Models.Pedido
@{
    ViewData["Title"] = $"Comprobante #{Model.PedidoId}";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .comprobante {
        background: white;
        border-radius: 12px;
        max-width: 580px;
        margin: 0 auto;
        box-shadow: 0 2px 20px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .comp-header {
        background: linear-gradient(135deg,#198754,#146c43);
        padding: 28px;
        color: white;
        text-align: center;
    }

        .comp-header h3 {
            font-family: 'Playfair Display',serif;
            margin: 0 0 4px;
        }

    .comp-body {
        padding: 28px;
    }

    .comp-row {
        display: flex;
        justify-content: space-between;
        padding: 6px 0;
        font-size: 0.85rem;
        border-bottom: 1px solid #f0f0f0;
    }

        .comp-row:last-child {
            border-bottom: none;
        }

    .comp-section {
        font-size: 0.67rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #aaa;
        margin: 16px 0 8px;
    }

    .tabla-comp th {
        background: #146c43;
        color: white;
        font-size: 0.7rem;
        text-transform: uppercase;
    }

    .tabla-comp td {
        font-size: 0.82rem;
        vertical-align: middle;
    }

    .total-final {
        background: #f0faf4;
        border-radius: 8px;
        padding: 14px 18px;
        margin-top: 16px;
    }

    .btn-print {
        background: #198754;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 10px 24px;
        font-size: 0.82rem;
        font-weight: 600;
        cursor: pointer;
    }

    .btn-volver {
        background: transparent;
        color: #666;
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 10px 18px;
        font-size: 0.82rem;
        text-decoration: none;
    }
</style>

<div class="comprobante">
    <div class="comp-header">
        <div style="font-size:2rem;margin-bottom:8px;"><i class="bi bi-check-circle-fill"></i></div>
        <h3>Comprobante de Venta</h3>
        <div style="font-size:0.85rem;opacity:0.8;">Pedido #@Model.PedidoId.ToString("D6")</div>
        <div style="font-size:0.78rem;opacity:0.6;margin-top:4px;">
            @Model.FechaPedido.ToString("dd/MM/yyyy HH:mm")
        </div>
    </div>

    <div class="comp-body">
        <div class="comp-section">Datos del Cliente</div>
        <div class="comp-row"><span>Nombre</span><span class="fw-semibold">@Model.Clientes?.Nombres</span></div>
        <div class="comp-row"><span>Correo</span><span>@Model.Clientes?.CorreoElectronico</span></div>

        <div class="comp-section">Envío</div>
        <div class="comp-row"><span>Dirección</span><span>@Model.DireccionEnvio?.CalleAvenida</span></div>
        <div class="comp-row"><span>Distrito</span><span>@Model.DireccionEnvio?.Distrito</span></div>
        <div class="comp-row"><span>Referencia</span><span>@Model.DireccionEnvio?.Referencia</span></div>

        <div class="comp-section">Método de Pago</div>
        <div class="comp-row">
            <span>Pago</span>
            <span class="fw-semibold" style="color:#198754;">@Model.MetodoPago?.DescripcionPago</span>
        </div>

        <div class="comp-section">Productos</div>
        <table class="table tabla-comp align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-2">Prenda</th>
                    <th>Talla/Color</th>
                    <th class="text-center">Cant.</th>
                    <th class="text-end pe-2">Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model.Detalles)
                {
                    <tr>
                        <td class="ps-2">@d.Variante?.Prenda?.NombrePrenda</td>
                        <td style="font-size:0.75rem;color:#666;">@d.Variante?.Talla / @d.Variante?.Color</td>
                        <td class="text-center">@d.Cantidad</td>
                        <td class="text-end pe-2">S/ @((d.Cantidad * d.PrecioUnitario).ToString("N2"))</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="total-final d-flex justify-content-between align-items-center">
            <span class="fw-bold" style="font-size:0.9rem;">TOTAL PAGADO</span>
            <span style="font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:700;color:#198754;">
                S/ @Model.TotalCompra.ToString("N2")
            </span>
        </div>

        <div class="d-flex gap-3 mt-4 justify-content-center">
            <button class="btn-print" onclick="window.print()">
                <i class="bi bi-printer me-2"></i>IMPRIMIR
            </button>
            <a asp-action="NuevaVenta" class="btn-volver">
                <i class="bi bi-plus-circle me-1"></i>Nueva Venta
            </a>
            <a asp-action="Index" class="btn-volver">
                <i class="bi bi-house me-1"></i>Panel
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <style media="print">
        .navbar-aleana, .topbar, footer, .btn-print, .btn-volver {
            display: none !important;
        }

        .comprobante {
            box-shadow: none;
            max-width: 100%;
        }
    </style>
}