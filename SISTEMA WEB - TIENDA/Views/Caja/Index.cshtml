@{
    ViewData["Title"] = "Panel de Caja";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var cajaAbierta = ViewBag.CajaAbierta as SISTEMA_WEB___TIENDA.Models.RegistroCaja;
    var pedidosHoy = ViewBag.PedidosHoy as List<SISTEMA_WEB___TIENDA.Models.Pedido>
                      ?? new List<SISTEMA_WEB___TIENDA.Models.Pedido>();
    decimal totalHoy = ViewBag.TotalVentasHoy ?? 0m;
    int pedidosTotalHoy = ViewBag.TotalPedidosHoy ?? 0;
    string cajeroNombre = ViewBag.CajeroNombre ?? "Cajero";
}

<style>
    .caja-header {
        background: linear-gradient(135deg, #198754, #146c43);
        border-radius: 14px;
        padding: 28px 32px;
        color: white;
        margin-bottom: 24px;
        position: relative;
        overflow: hidden;
    }

        .caja-header::after {
            content: '';
            position: absolute;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
            top: -60px;
            right: -40px;
            border-radius: 50%;
            pointer-events: none;
        }

        .caja-header h4 {
            font-family: 'Playfair Display', serif;
            font-size: 1.6rem;
            margin: 0 0 4px;
        }

    .stat-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        padding: 18px 22px;
        border-left: 4px solid #198754;
        height: 100%;
    }

    .stat-label {
        font-size: 0.67rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #aaa;
        margin-bottom: 6px;
    }

    .stat-valor {
        font-family: 'Playfair Display', serif;
        font-size: 1.6rem;
        font-weight: 700;
        color: #198754;
        line-height: 1;
    }

    .action-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        padding: 22px;
        transition: transform 0.2s;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .action-card:hover {
            transform: translateY(-3px);
        }

    .action-icon {
        width: 46px;
        height: 46px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        margin-bottom: 10px;
    }

    .btn-accion {
        width: 100%;
        border: none;
        border-radius: 7px;
        padding: 9px;
        font-size: 0.76rem;
        font-weight: 600;
        letter-spacing: 0.7px;
        text-transform: uppercase;
        cursor: pointer;
        text-decoration: none;
        display: block;
        text-align: center;
        transition: opacity 0.2s;
        margin-top: auto;
        color: white;
    }

        .btn-accion:hover {
            opacity: 0.82;
            color: white;
        }

    .section-lbl {
        font-size: 0.67rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #aaa;
        margin: 24px 0 12px;
    }

    .tabla-caja th {
        background: #146c43;
        color: white;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        font-weight: 600;
    }

    .tabla-caja td {
        font-size: 0.875rem;
        vertical-align: middle;
    }

    .tabla-caja tbody tr:hover {
        background: #f0faf4;
    }

    .badge-estado {
        border-radius: 6px;
        padding: 3px 9px;
        font-size: 0.7rem;
        font-weight: 700;
    }

    .caja-status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 14px;
        border-radius: 20px;
        font-size: 0.78rem;
        font-weight: 700;
    }
</style>

<!-- HEADER -->
<div class="caja-header">
    <div style="position:relative;z-index:1;">
        <p class="mb-1" style="font-size:0.7rem;letter-spacing:2px;color:rgba(255,255,255,0.6);text-transform:uppercase;">
            <i class="bi bi-person-badge me-1"></i>Módulo de Caja
        </p>
        <h4>Hola, @cajeroNombre.Split(' ').First()</h4>
        <small style="color:rgba(255,255,255,0.6);">
            @DateTime.Now.ToString("dddd dd 'de' MMMM, yyyy — HH:mm", new System.Globalization.CultureInfo("es-PE"))
        </small>
        <div style="margin-top:12px;">
            @if (cajaAbierta != null)
            {
                <span class="caja-status" style="background:rgba(255,255,255,0.2);color:white;">
                    <i class="bi bi-circle-fill" style="font-size:0.5rem;color:#90ee90;"></i>
                    Caja abierta desde @cajaAbierta.FechaApertura.ToString("HH:mm")
                </span>
            }
            else
            {
                <span class="caja-status" style="background:rgba(255,0,0,0.2);color:white;">
                    <i class="bi bi-circle-fill" style="font-size:0.5rem;color:#ff6b6b;"></i>
                    Caja cerrada
                </span>
            }
        </div>
    </div>
</div>

@if (TempData["OK"] != null)
{
    <div class="alert alert-success alert-dismissible fade show small py-2 mb-3">
        <i class="bi bi-check-circle me-1"></i>@TempData["OK"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorCaja"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show small py-2 mb-3">
        <i class="bi bi-exclamation-circle me-1"></i>@TempData["ErrorCaja"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- STATS -->
<div class="section-lbl mt-0">Resumen del día</div>
<div class="row g-3 mb-2">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-label"><i class="bi bi-currency-dollar me-1"></i>Ventas Hoy</div>
            <div class="stat-valor">S/ @totalHoy.ToString("N2")</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card" style="border-left-color:#c9a84c;">
            <div class="stat-label"><i class="bi bi-bag-check me-1"></i>Pedidos Hoy</div>
            <div class="stat-valor" style="color:#c9a84c;">@pedidosTotalHoy</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card" style="border-left-color:#1a4a8a;">
            <div class="stat-label"><i class="bi bi-clock me-1"></i>Apertura</div>
            <div class="stat-valor" style="color:#1a4a8a;font-size:1.2rem;padding-top:4px;">
                @(cajaAbierta != null ? cajaAbierta.FechaApertura.ToString("HH:mm") : "—")
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card" style="border-left-color:@(cajaAbierta != null ? "#198754" : "#dc3545");">
            <div class="stat-label"><i class="bi bi-toggle-on me-1"></i>Estado Caja</div>
            <div class="stat-valor" style="color:@(cajaAbierta != null ? "#198754" : "#dc3545");font-size:1rem;padding-top:6px;">
                @(cajaAbierta != null ? "Abierta" : "Cerrada")
            </div>
        </div>
    </div>
</div>

<!-- ACCIONES -->
<div class="section-lbl">Acciones</div>
<div class="row g-3 mb-4">

    @* 1. Abrir / Cerrar Caja *@
    <div class="col-12 col-sm-6 col-md-3 d-flex">
        <div class="action-card w-100">
            <div class="action-icon" style="background:#19875422;color:#198754;">
                <i class="bi bi-box-arrow-in-right"></i>
            </div>
            <h6 style="font-family:'Playfair Display',serif;font-weight:600;">
                @(cajaAbierta != null ? "Cerrar Caja" : "Abrir Caja")
            </h6>
            <p class="text-muted mb-3" style="font-size:0.78rem;flex:1;">
                @(cajaAbierta != null ? "Registrar cierre y monto final." : "Iniciar turno con monto inicial.")
            </p>
            @if (cajaAbierta != null)
            {
                <a asp-action="CerrarCaja" asp-controller="Caja" class="btn-accion" style="background:#dc3545;">
                    <i class="bi bi-box-arrow-right me-1"></i>Cerrar Caja
                </a>
            }
            else
            {
                <a asp-action="AbrirCaja" asp-controller="Caja" class="btn-accion" style="background:#198754;">
                    <i class="bi bi-box-arrow-in-right me-1"></i>Abrir Caja
                </a>
            }
        </div>
    </div>

    @* 2. Nueva Venta *@
    <div class="col-12 col-sm-6 col-md-3 d-flex">
        <div class="action-card w-100">
            <div class="action-icon" style="background:#c9a84c22;color:#c9a84c;">
                <i class="bi bi-cart-plus-fill"></i>
            </div>
            <h6 style="font-family:'Playfair Display',serif;font-weight:600;">Nueva Venta</h6>
            <p class="text-muted mb-3" style="font-size:0.78rem;flex:1;">Registrar una venta en caja.</p>
            <a asp-action="NuevaVenta" asp-controller="Caja"
               class="btn-accion"
               style="background:@(cajaAbierta != null ? "#c9a84c" : "#aaa");"
               onclick="@(cajaAbierta == null ? "return confirm('Debes abrir la caja primero.')" : "")">
                <i class="bi bi-plus-circle me-1"></i>Iniciar
            </a>
        </div>
    </div>

    @* 3. Ventas del Día *@
    <div class="col-12 col-sm-6 col-md-3 d-flex">
        <div class="action-card w-100">
            <div class="action-icon" style="background:#1a4a8a22;color:#1a4a8a;">
                <i class="bi bi-calendar-day-fill"></i>
            </div>
            <h6 style="font-family:'Playfair Display',serif;font-weight:600;">Ventas del Día</h6>
            <p class="text-muted mb-3" style="font-size:0.78rem;flex:1;">Ver todas las ventas de hoy.</p>
            <a asp-action="VentasDelDia" asp-controller="Caja" class="btn-accion" style="background:#1a4a8a;">
                <i class="bi bi-arrow-right-circle me-1"></i>Ver
            </a>
        </div>
    </div>

    @* 4. Pedidos *@
    <div class="col-12 col-sm-6 col-md-3 d-flex">
        <div class="action-card w-100">
            <div class="action-icon" style="background:#6b1a2a18;color:#6b1a2a;">
                <i class="bi bi-bag-check-fill"></i>
            </div>
            <h6 style="font-family:'Playfair Display',serif;font-weight:600;">Pedidos</h6>
            <p class="text-muted mb-3" style="font-size:0.78rem;flex:1;">Consultar y gestionar pedidos.</p>
            <a asp-controller="Pedidos" asp-action="Index" class="btn-accion" style="background:#6b1a2a;">
                <i class="bi bi-arrow-right-circle me-1"></i>Ver Pedidos
            </a>
        </div>
    </div>
</div>

<!-- VENTAS RECIENTES DEL DÍA -->
@if (pedidosHoy.Any())
{
    <div class="section-lbl">Ventas recientes de hoy</div>
    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="table-responsive">
            <table class="table tabla-caja align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-3"># Pedido</th>
                        <th>Cliente</th>
                        <th>Hora</th>
                        <th>Método Pago</th>
                        <th>Estado</th>
                        <th class="text-end">Total</th>
                        <th class="text-center pe-3">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in pedidosHoy)
                    {
                        var (bg, color) = p.Estado?.NombreEstado switch
                        {
                            "Pendiente" => ("#fef9c3", "#854d0e"),
                            "Procesando" => ("#dbeafe", "#1e40af"),
                            "Enviado" => ("#e0e7ff", "#3730a3"),
                            "Entregado" => ("#d1fae5", "#065f46"),
                            "Cancelado" => ("#fee2e2", "#991b1b"),
                            _ => ("#f3f4f6", "#374151")
                        };
                        <tr>
                            <td class="ps-3 fw-bold font-monospace" style="color:#198754;">#@p.PedidoId.ToString("D6")</td>
                            <td>@p.Clientes?.Nombres</td>
                            <td style="color:#666;font-size:0.82rem;">@p.FechaPedido.ToString("HH:mm")</td>
                            <td style="color:#666;font-size:0.82rem;">@p.MetodoPago?.DescripcionPago</td>
                            <td><span class="badge-estado" style="background:@bg;color:@color;">@p.Estado?.NombreEstado</span></td>
                            <td class="text-end fw-bold" style="color:#198754;">S/ @p.TotalCompra.ToString("N2")</td>
                            <td class="text-center pe-3">
                                <div class="d-flex justify-content-center gap-1">
                                    <a asp-action="ConsultarPedido" asp-controller="Caja" asp-route-id="@p.PedidoId"
                                       class="btn btn-sm text-white" style="background:#1a4a8a;border-radius:6px;font-size:0.72rem;">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Comprobante" asp-controller="Caja" asp-route-id="@p.PedidoId"
                                       class="btn btn-sm text-white" style="background:#198754;border-radius:6px;font-size:0.72rem;">
                                        <i class="bi bi-receipt"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}