@model SISTEMA_WEB___TIENDA.Models.Pedido
@{
    ViewData["Title"] = $"Pedido #{Model.PedidoId}";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .caja-header {
        background: linear-gradient(135deg,#198754,#146c43);
        border-radius: 14px;
        padding: 22px 28px;
        color: white;
        margin-bottom: 24px;
    }

        .caja-header h4 {
            font-family: 'Playfair Display',serif;
            font-size: 1.4rem;
            margin: 0;
        }

    .info-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        padding: 22px;
        height: 100%;
    }

    .field-lbl {
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #aaa;
        margin-bottom: 3px;
    }

    .field-val {
        font-size: 0.9rem;
        font-weight: 500;
        color: #1c1c1c;
    }

    .tabla-det th {
        background: #146c43;
        color: white;
        font-size: 0.72rem;
        text-transform: uppercase;
    }

    .tabla-det td {
        font-size: 0.875rem;
        vertical-align: middle;
    }

    .badge-estado {
        border-radius: 6px;
        padding: 4px 12px;
        font-size: 0.75rem;
        font-weight: 700;
    }

    .field-input {
        width: 100%;
        border: none;
        border-bottom: 1.5px solid #ddd;
        padding: 9px 0;
        font-size: 0.9rem;
        background: transparent;
        outline: none;
        font-family: 'Inter',sans-serif;
    }

        .field-input:focus {
            border-bottom-color: #198754;
        }

    .btn-guardar {
        background: #198754;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 9px 22px;
        font-size: 0.82rem;
        font-weight: 600;
        cursor: pointer;
    }
</style>

@{
    var (bgE, colorE) = Model.Estado?.NombreEstado switch
    {
        "Pendiente" => ("#fef9c3", "#854d0e"),
        "Procesando" => ("#dbeafe", "#1e40af"),
        "Enviado" => ("#e0e7ff", "#3730a3"),
        "Entregado" => ("#d1fae5", "#065f46"),
        "Cancelado" => ("#fee2e2", "#991b1b"),
        _ => ("#f3f4f6", "#374151")
    };
}

<div class="caja-header d-flex align-items-center justify-content-between flex-wrap gap-3">
    <div>
        <p class="mb-1" style="font-size:0.7rem;letter-spacing:2px;color:rgba(255,255,255,0.6);text-transform:uppercase;">
            <i class="bi bi-bag-check me-1"></i>Caja — Pedidos
        </p>
        <h4>Pedido #@Model.PedidoId.ToString("D6")</h4>
    </div>
    <div class="d-flex gap-2 align-items-center">
        <span class="badge-estado" style="background:@bgE;color:@colorE;">@Model.Estado?.NombreEstado</span>
        <a asp-action="Comprobante" asp-route-id="@Model.PedidoId"
           class="btn btn-sm text-white" style="background:#198754;border-radius:8px;">
            <i class="bi bi-receipt me-1"></i>Comprobante
        </a>
        <a asp-action="Index" class="btn btn-sm" style="background:rgba(255,255,255,0.15);color:white;border-radius:8px;">
            <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
    </div>
</div>

@if (TempData["OK"] != null)
{
    <div class="alert alert-success small py-2 mb-3">
        <i class="bi bi-check-circle me-1"></i>@TempData["OK"]
    </div>
}

<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="info-card">
            <div class="field-lbl">Cliente</div>
            <div class="field-val">@Model.Clientes?.Nombres</div>
            <div class="field-lbl mt-2">Correo</div>
            <div class="field-val" style="font-size:0.82rem;">@Model.Clientes?.CorreoElectronico</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="info-card">
            <div class="field-lbl">Fecha</div>
            <div class="field-val">@Model.FechaPedido.ToString("dd/MM/yyyy HH:mm")</div>
            <div class="field-lbl mt-2">Método de Pago</div>
            <div class="field-val">@Model.MetodoPago?.DescripcionPago</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="info-card">
            <div class="field-lbl">Cambiar Estado</div>
            <form asp-action="CambiarEstadoPedido" method="post" class="mt-1">
                @Html.AntiForgeryToken()
                <input type="hidden" name="pedidoId" value="@Model.PedidoId" />
                <select name="estadoId" class="field-input" asp-items="ViewBag.Estados"></select>
                <button type="submit" class="btn-guardar mt-3">
                    <i class="bi bi-check-lg me-1"></i>Actualizar
                </button>
            </form>
        </div>
    </div>
</div>

<div class="info-card">
    <h6 style="font-family:'Playfair Display',serif;font-weight:600;margin-bottom:14px;">Productos</h6>
    <div class="table-responsive">
        <table class="table tabla-det align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-3">Prenda</th>
                    <th>Talla / Color</th>
                    <th class="text-center">Cantidad</th>
                    <th class="text-end">Precio Unit.</th>
                    <th class="text-end pe-3">Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model.Detalles)
                {
                    <tr>
                        <td class="ps-3 fw-semibold">@d.Variante?.Prenda?.NombrePrenda</td>
                        <td style="color:#666;font-size:0.82rem;">@d.Variante?.Talla / @d.Variante?.Color</td>
                        <td class="text-center">@d.Cantidad</td>
                        <td class="text-end">S/ @d.PrecioUnitario.ToString("N2")</td>
                        <td class="text-end pe-3 fw-bold" style="color:#198754;">S/ @((d.Cantidad * d.PrecioUnitario).ToString("N2"))</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr style="background:#f0faf4;">
                    <td colspan="4" class="text-end fw-bold" style="font-size:0.82rem;">TOTAL</td>
                    <td class="text-end pe-3 fw-bold" style="color:#198754;">S/ @Model.TotalCompra.ToString("N2")</td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>